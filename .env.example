# =============================================================================
# IBKR Client Portal Gateway (default broker — headless, no TWS required)
# Download: https://www.interactivebrokers.com/campus/ibkr-api-page/cpapi-v1/
# Start: ./bin/run.sh root/conf.yaml  then open https://localhost:5000 to login
# =============================================================================
IB_HOST=127.0.0.1
IB_PORT=5000
IB_ACCOUNT=                  # Paper accounts start with DU, live with U

# =============================================================================
# IBKR TWS / Gateway (optional — only for --broker ibkr-tws)
# Requires: uv sync --extra tws  and TWS/Gateway running locally
# Paper: IB_PORT=7497 | Live: IB_PORT=7496
# =============================================================================
# IBKR_USERNAME=
# IBKR_PASSWORD=

# =============================================================================
# News (Benzinga) — https://www.benzinga.com/apis
# =============================================================================
BENZINGA_API_KEY=

# =============================================================================
# Strategy defaults
# =============================================================================
MAX_POSITION_PCT=0.05
DEFAULT_STRATEGY=rsi
DEFAULT_BROKER=ibkr-rest

# Agent mode: autonomous (places orders on paper trade) or supervised (logs intent only)
AGENT_MODE=autonomous
AGENT_LOG_PATH=.trader/logs/agent.jsonl
AGENT_PROFILE_PATH=.trader/profile.json
