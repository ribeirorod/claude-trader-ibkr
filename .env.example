# =============================================================================
# IBKR Client Portal Gateway  (required — default broker)
# -----------------------------------------------------------------------------
# 1. Download the gateway zip from IBKR and unzip it:
#      wget https://download2.interactivebrokers.com/portal/clientportal.gw.zip
#      unzip clientportal.gw.zip -d clientportal.gw
# 2. Start it: cd clientportal.gw && ./bin/run.sh root/conf.yaml
# 3. Open https://localhost:5001 in your browser and log in once
# 4. Run ./scripts/start-gateway.sh to keep the session alive (ibeam)
# =============================================================================
IB_HOST=127.0.0.1
IB_PORT=5001
IB_ACCOUNT=                         # Paper accounts start with DU, live with U

# =============================================================================
# ibeam — session keepalive  (prevents the gateway from timing out)
# -----------------------------------------------------------------------------
# IBEAM_AUTHENTICATE=False  →  manual login once in browser, ibeam keeps alive
# IBEAM_AUTHENTICATE=True   →  fully automatic; requires IBEAM_KEY (TOTP secret)
# To get your TOTP secret: re-enroll 2FA in IBKR settings using a standard
# authenticator app (Google Authenticator, Authy) and copy the base32 key shown.
# =============================================================================
IBEAM_ACCOUNT=                       # Same as IB_ACCOUNT
IBEAM_PASSWORD=                      # Your IBKR login password
IBEAM_GATEWAY_BASE_URL=https://localhost:5001
IBEAM_LOG_LEVEL=WARNING
IBEAM_AUTHENTICATE=False
#IBEAM_KEY=                          # Base32 TOTP secret — only if IBEAM_AUTHENTICATE=True

# =============================================================================
# IBKR TWS / Gateway  (optional — only needed for --broker ibkr-tws)
# Requires: uv sync --extra tws  and TWS or IB Gateway running locally
# Paper: IB_PORT=7497 | Live: IB_PORT=7496
# =============================================================================
#IBKR_USERNAME=
#IBKR_PASSWORD=

# =============================================================================
# News — Benzinga  https://www.benzinga.com/apis
# Required for: trader news, sentiment signals, and strategy --with-news flag
# =============================================================================
BENZINGA_API_KEY=

# =============================================================================
# Financial Modeling Prep  https://financialmodelingprep.com/developer/docs
# Optional — used for fundamental screening (CANSLIM, earnings data)
# =============================================================================
#FM_API_KEY=

# =============================================================================
# Strategy defaults
# =============================================================================
MAX_POSITION_PCT=0.05
DEFAULT_STRATEGY=rsi
DEFAULT_BROKER=ibkr-rest

# =============================================================================
# Autonomous agent settings
# -----------------------------------------------------------------------------
# AGENT_MODE=supervised  →  logs ORDER_INTENT but never places real orders (safe default)
# AGENT_MODE=autonomous  →  executes approved orders automatically via the conductor
# Start with supervised until you trust the system on your account.
# =============================================================================
AGENT_MODE=supervised
AGENT_LOG_PATH=.trader/logs/agent.jsonl
AGENT_PROFILE_PATH=.trader/profile.json
